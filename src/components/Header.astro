---
const { pathname } = Astro.url;

// Función para normalizar y comparar rutas
const isActive = (path: string) => {
  const normalizedPath = path.endsWith("/") ? path : `${path}/`;
  const normalizedCurrent = pathname.endsWith("/") ? pathname : `${pathname}/`;
  return normalizedCurrent === normalizedPath;
};
---

<header class="bg-white/80 backdrop-blur-sm border-b border-black/5 sticky top-0 z-900 transition-all duration-300">
  <div class="container">
    <div class="flex justify-between items-center h-20">
      <a href={import.meta.env.BASE_URL}>
        <img
          src={`${import.meta.env.BASE_URL}logo.svg`}
          alt="MediaBros Latam"
          class="h-8 w-auto block"
        />
      </a>
      <nav>
        <ul class="flex list-none gap-8 items-center">
          <li>
            <a
              href={`${import.meta.env.BASE_URL}`}
              class={`no-underline font-display font-medium text-[0.95rem] transition-colors duration-200 hover:text-blue ${isActive(import.meta.env.BASE_URL) ? "text-blue underline decoration-2 underline-offset-4" : "text-navy"}`}
              >Cursos</a
            >
          </li>
          <li>
            <a
              href={`${import.meta.env.BASE_URL}guia`}
              class={`no-underline font-display font-medium text-[0.95rem] transition-colors duration-200 hover:text-blue ${isActive(`${import.meta.env.BASE_URL}guia`) ? "text-blue underline decoration-2 underline-offset-4" : "text-navy"}`}
              >Guía B2B</a
            >
          </li>
          <li>
            <a
              href={`${import.meta.env.BASE_URL}auditoria`}
              class={`no-underline font-display font-medium text-[0.95rem] transition-colors duration-200 hover:text-blue ${isActive(`${import.meta.env.BASE_URL}auditoria`) ? "text-blue underline decoration-2 underline-offset-4" : "text-navy"}`}
              >Auditoría</a
            >
          </li>
          <li>
            <a
              href={`${import.meta.env.BASE_URL}diagnostico`}
              class={`no-underline bg-blue text-white px-5 py-2.5 rounded-full font-display font-semibold text-[0.9rem] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-blue ${isActive(`${import.meta.env.BASE_URL}diagnostico`) ? "ring-2 ring-blue ring-offset-2" : ""}`}
              >Diagnóstico Gratis</a
            >
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>
