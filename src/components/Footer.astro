---
import styles from "./Footer.module.css";
const year = new Date().getFullYear();
---

<footer class={styles.footer}>
  <div class="container">
    <div class={styles.footerContent}>
      <div class={styles.brand}>
        <h4>MediaBros Latam</h4>
        <p>Expertos en generación de demanda B2B.</p>
      </div>
      <div class={styles.links}>
        <a href="https://www.linkedin.com/company/mediabros" target="_blank"
          >LinkedIn</a
        >
        <a href="mailto:hola@mediabroslatam.com">Contacto</a>
      </div>
    </div>
    <div class={styles.copyright}>
      <p>&copy; {year} Mediabros Latam. Todos los derechos reservados.</p>
      <p class={styles.disclaimer}>
        This site is not part of the Meta website or Meta Inc. Additionally,
        this site is NOT endorsed by Meta in any way. META is a trademark of
        META, Inc.
      </p>
    </div>
  </div>
</footer>
