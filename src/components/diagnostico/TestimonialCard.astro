---
interface Props {
  quote: string;
  authorName: string;
  authorRole: string;
  videoUrl?: string;
  class?: string;
}
const { quote, authorName, authorRole, videoUrl, class: className = "" } = Astro.props;
---
<div class:list={["bg-slate-50 rounded-xl overflow-hidden shadow-card border border-slate-100 flex flex-col", className]}>
  <div class="w-full bg-slate-900 relative">
    {videoUrl ? (
      <video src={videoUrl} class="w-full h-60 object-cover" controls playsinline></video>
    ) : (
      <div class="w-full h-60 bg-brand-blue flex items-center justify-center text-white/50">
        <m-icon class="material-symbols-outlined text-4xl">play_circle</m-icon>
      </div>
    )}
  </div>
  <div class="p-6 flex flex-col flex-1">
    <div class="flex items-center gap-1 mb-4 text-yellow-400">
      <m-icon class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 1;">star</m-icon>
      <m-icon class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 1;">star</m-icon>
      <m-icon class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 1;">star</m-icon>
      <m-icon class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 1;">star</m-icon>
      <m-icon class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 1;">star</m-icon>
    </div>
    <p class="text-slate-700 mb-6 flex-1 italic">
      "{quote}"
    </p>
    <div>
      <p class="font-bold text-navy">{authorName}</p>
      <p class="text-sm text-slate-500">{authorRole}</p>
    </div>
  </div>
</div>
