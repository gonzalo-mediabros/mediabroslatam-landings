---
interface Props {
  text: string;
  icon?: string;
  class?: string;
}

const { text, icon = "verified", class: className = "" } = Astro.props;
---

<span
  class:list={[
    "inline-flex items-center gap-2 bg-brand-blue/10 border border-brand-blue/30 text-blue-400 rounded-full px-4 py-2 text-xs font-bold uppercase tracking-wide",
    className
  ]}
>
  {icon && (
    <span class="material-symbols-outlined leading-none text-[14px]">
      {icon}
    </span>
  )}
  {text}
</span>
