---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Acceder al curso gratuito",
  subtitle = "Completa tus datos para empezar ahora mismo y recibir la guía estratégica.",
} = Astro.props;

const SCRIPT_URL = import.meta.env.PUBLIC_SCRIPT_URL;
---

<!-- CourseForm2: dark glass form card — exclusive to index2 landing -->
<div class="bg-[rgba(22,26,41,0.8)] backdrop-blur-xl border border-white/10 rounded-xl p-10 shadow-[0_40px_100px_-20px_rgba(0,0,0,0.5)]">
  <h2 class="font-display text-2xl font-bold text-white mb-2">{title}</h2>
  <p class="text-sm text-text-light mb-8 leading-relaxed">{subtitle}</p>

  <form id="course-form-2" data-url={SCRIPT_URL} class="contents">
    <div class="flex flex-col gap-5">
      <div class="flex flex-col gap-1.5">
        <label for="c2-name" class="block text-xs font-semibold text-text-light uppercase tracking-wide ml-1">Nombre</label>
        <input
          type="text"
          id="c2-name"
          name="name"
          required
          placeholder="Tu nombre"
          class="w-full py-4 px-5 bg-white/5 border border-white/10 rounded-md text-white placeholder:text-white/30 outline-none transition-all focus:border-brand-blue focus:bg-white/8"
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="c2-email" class="block text-xs font-semibold text-text-light uppercase tracking-wide ml-1">Email</label>
        <input
          type="email"
          id="c2-email"
          name="email"
          required
          placeholder="tu@empresa.com"
          class="w-full py-4 px-5 bg-white/5 border border-white/10 rounded-md text-white placeholder:text-white/30 outline-none transition-all focus:border-brand-blue focus:bg-white/8"
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="c2-company" class="block text-xs font-semibold text-text-light uppercase tracking-wide ml-1">Empresa</label>
        <input
          type="text"
          id="c2-company"
          name="company"
          required
          placeholder="Nombre de empresa"
          class="w-full py-4 px-5 bg-white/5 border border-white/10 rounded-md text-white placeholder:text-white/30 outline-none transition-all focus:border-brand-blue focus:bg-white/8"
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="c2-position" class="block text-xs font-semibold text-text-light uppercase tracking-wide ml-1">Cargo</label>
        <input
          type="text"
          id="c2-position"
          name="position"
          required
          placeholder="Ej. Director Comercial"
          class="w-full py-4 px-5 bg-white/5 border border-white/10 rounded-md text-white placeholder:text-white/30 outline-none transition-all focus:border-brand-blue focus:bg-white/8"
        />
      </div>
    </div>

    <button
      type="submit"
      class="w-full mt-6 py-5 bg-brand-blue text-white border-none rounded-lg font-display font-bold uppercase tracking-wide cursor-pointer transition-all hover:bg-brand-blue-hover hover:-translate-y-0.5 shadow-blue"
    >
      ACCEDER AL CURSO GRATUITO
    </button>

    <p class="flex items-center justify-center gap-1.5 text-xs text-text-light mt-6">
      <span class="material-symbols-outlined text-base leading-none">lock</span>
      Tus datos están seguros y no enviamos spam.
    </p>
  </form>

  <div id="form-feedback-2" class="hidden">
    <div class="success-msg hidden text-center py-8 font-bold text-emerald-400">
      <span class="material-symbols-outlined text-4xl block mb-2">check_circle</span>
      <p>¡Acceso concedido! Revisá tu email para comenzar.</p>
    </div>
    <div class="error-msg hidden text-center py-8 font-bold text-red-400">
      <span class="material-symbols-outlined text-4xl block mb-2">error</span>
      <p>Hubo un error. Por favor reintentá.</p>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById("course-form-2") as HTMLFormElement;
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.innerText;
      submitBtn.disabled = true;
      submitBtn.innerText = "Preparando acceso...";

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      const SCRIPT_URL = form.dataset.url;

      try {
        if (!SCRIPT_URL) throw new Error("API URL missing");
        await fetch(SCRIPT_URL, {
          method: "POST",
          mode: "no-cors",
          body: JSON.stringify(data),
        });
        form.style.display = "none";
        document.getElementById("form-feedback-2")?.classList.remove("hidden");
        document.querySelector(".success-msg")?.classList.remove("hidden");
      } catch (err) {
        console.error(err);
        submitBtn.disabled = false;
        submitBtn.innerText = originalText;
      }
    });
  }
</script>
