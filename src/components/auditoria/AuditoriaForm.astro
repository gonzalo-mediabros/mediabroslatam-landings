---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---
<div class:list={["bg-brand-dark/80 backdrop-blur-md rounded-2xl p-6 lg:p-10 border border-white/10 shadow-premium", className]}>
  <div class="text-center mb-8">
    <h3 class="font-display font-bold text-2xl lg:text-3xl text-white mb-2">
      Solicita tu Auditoría
    </h3>
    <p class="text-slate-300 text-sm">
      Completa los datos y te contactaremos para coordinar.
    </p>
  </div>
  
  <form class="space-y-4">
    <div>
      <input type="text" placeholder="Nombre completo" class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-4 text-white placeholder-slate-400 focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none transition-base" />
    </div>
    <div>
      <input type="email" placeholder="Correo electrónico (Corporativo)" class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-4 text-white placeholder-slate-400 focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none transition-base" />
    </div>
    <div>
      <input type="tel" placeholder="WhatsApp (Con código de país)" class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-4 text-white placeholder-slate-400 focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none transition-base" />
    </div>
    <div>
      <input type="text" placeholder="Sitio Web de la empresa" class="w-full bg-white/5 border border-white/10 rounded-lg px-5 py-4 text-white placeholder-slate-400 focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none transition-base" />
    </div>
    <button type="button" class="w-full bg-brand-blue hover:bg-blue-600 text-white font-bold py-4 px-8 rounded-lg shadow-blue transition-all disabled:opacity-50 mt-4 flex items-center justify-center gap-2">
      <m-icon class="material-symbols-outlined">rocket_launch</m-icon>
      Solicitar Auditoría Gratis
    </button>
  </form>
</div>
