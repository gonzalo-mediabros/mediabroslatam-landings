---
interface Props {
  title?: string;
  subtitle?: string;
  buttonText?: string;
  theme?: "light" | "dark";
}

const {
  title = "Solicitá tu recurso gratuito",
  subtitle = "Completá tus datos para empezar ahora mismo.",
  buttonText = "Quiero empezar",
  theme = "dark",
} = Astro.props;

const isDark = theme === "dark";

// Contenedor principal
const containerClasses = isDark
  ? "bg-[rgba(22,26,41,0.8)] backdrop-blur-xl border border-white/10 rounded-xl  shadow-[0_40px_100px_-20px_rgba(0,0,0,0.5)]"
  : "bg-white rounded-xl shadow-premium  border border-slate-100";

// Título y Subtítulo
const titleClasses = isDark
  ? "font-display text-2xl font-bold text-white mb-2 text-center lg:text-left"
  : "text-2xl font-display font-bold text-navy mb-2 text-center";

const subtitleClasses = isDark
  ? "text-sm text-text-light mb-8 leading-relaxed text-center lg:text-left"
  : "text-slate-500 text-center mb-8";

// Labels
const labelClasses = isDark
  ? "block text-xs font-semibold text-text-light uppercase tracking-wide ml-1"
  : "text-sm font-semibold text-slate-700";

// Inputs
const inputClasses = isDark
  ? "w-full py-4 px-5 bg-white/5 border border-white/10 rounded-md text-white placeholder:text-white/30 outline-none transition-all focus:border-brand-blue focus:bg-white/8"
  : "w-full bg-slate-50 border border-slate-200 rounded-md px-4 py-3 text-navy focus:outline-none focus:border-brand-blue focus:ring-1 focus:ring-brand-blue transition-base";

// Botón
const buttonClasses = isDark
  ? "w-full mt-6 py-5 bg-brand-blue text-white border-none rounded-md font-display font-bold uppercase tracking-wide cursor-pointer transition-all hover:bg-brand-blue-hover hover:-translate-y-0.5 shadow-blue"
  : "w-full bg-brand-blue hover:bg-brand-blue-hover text-white rounded-md py-4 font-bold shadow-blue transition-base mt-4 cursor-pointer text-lg";

// Form attributes
const formId = `lead-form-${Math.random().toString(36).substr(2, 9)}`;
---

<div class={containerClasses + " p-4 sm:p-10"}>
  {title && <h3 class={titleClasses}>{title}</h3>}
  {subtitle && <p class={subtitleClasses}>{subtitle}</p>}

  <form
    id={formId}
    class={isDark ? "contents" : "flex flex-col gap-4"}
    onsubmit="event.preventDefault();"
  >
    <div class="flex flex-col gap-5">
      <div class="flex flex-col gap-1.5">
        <label for={`${formId}-name`} class={labelClasses}
          >Nombre completo</label
        >
        <input
          type="text"
          id={`${formId}-name`}
          name="nombre"
          required
          placeholder="Ej. Juan Pérez"
          class={inputClasses}
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for={`${formId}-website`} class={labelClasses}>Sitio web</label>
        <input
          type="url"
          id={`${formId}-website`}
          name="website"
          required
          placeholder="Ej. www.tuempresa.com"
          class={inputClasses}
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for={`${formId}-email`} class={labelClasses}
          >Email corporativo</label
        >
        <input
          type="email"
          id={`${formId}-email`}
          name="email"
          required
          placeholder="tu@empresa.com"
          class={inputClasses}
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for={`${formId}-phone`} class={labelClasses}
          >Teléfono (WhatsApp)</label
        >
        <input
          type="tel"
          id={`${formId}-phone`}
          name="telefono"
          required
          placeholder="+54 9 11 1234-5678"
          class={inputClasses}
        />
      </div>
    </div>

    <button type="submit" class={buttonClasses}>
      {buttonText}
    </button>

    <div
      class={isDark
        ? "mt-6 flex flex-wrap justify-center items-center text-center gap-4 lg:gap-6 text-[11px] font-medium text-slate-400 uppercase tracking-wide [&_.footer-item]:flex [&_.footer-item]:items-center [&_.footer-item]:gap-1.5 [&_.material-symbols-outlined]:text-[16px]"
        : "mt-6 flex flex-wrap justify-center items-center text-center gap-4 lg:gap-6 text-[11px] font-semibold text-brand-blue uppercase tracking-wide [&_.footer-item]:flex [&_.footer-item]:items-center [&_.footer-item]:gap-1.5 [&_.material-symbols-outlined]:text-[16px]"}
    >
      <slot name="footer" />
    </div>
  </form>
</div>
