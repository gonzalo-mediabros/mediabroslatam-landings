---
interface Props {
  text: string;
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost';
  class?: string;
}

const { text, href, variant = 'primary', class: className } = Astro.props;

const Element = href ? 'a' : 'button';

const baseClasses = "inline-flex items-center justify-center gap-3 py-5 px-10 rounded-lg font-display font-extrabold text-lg no-underline transition-all duration-300 cursor-pointer border-none uppercase -tracking-tight";

const variantClasses = {
  primary: "bg-blue text-white shadow-[0_10px_20px_rgba(20,139,239,0.2)] hover:-translate-y-0.5 hover:scale-[1.02] hover:shadow-[0_15px_30px_rgba(20,139,239,0.3)] hover:bg-white hover:text-navy",
  outline: "bg-transparent border-2 border-blue text-blue",
  ghost: "",
};
---

<Element
  href={href}
  class:list={[baseClasses, variantClasses[variant], className]}
>
  <slot name="before" />
  <span>{text}</span>
  <slot name="after" />
</Element>
