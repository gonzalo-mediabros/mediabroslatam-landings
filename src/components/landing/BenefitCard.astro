---
interface Props {
  icon: string;
  title: string;
  description: string;
}
const { icon, title, description } = Astro.props;
---

<div class="group bg-brand-graybg rounded-xl border border-black/3 p-6 md:p-8 flex flex-row items-start gap-4 transition-all duration-[--transition-base] hover:-translate-y-1 hover:shadow-card-hover hover:border-brand-blue/20">
  <div class="w-12 h-12 rounded-md bg-brand-blue text-white flex items-center justify-center shrink-0 transition-all duration-[--transition-base] group-hover:bg-brand-blue-hover">
    <span class="material-symbols-outlined text-[1.5rem]">{icon}</span>
  </div>
  <div>
    <h3 class="font-display text-lg font-bold text-text-dark m-0 mb-1 tracking-tight">{title}</h3>
    <p class="text-sm text-text-muted m-0 leading-relaxed">{description}</p>
  </div>
</div>
