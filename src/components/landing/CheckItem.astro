---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<li class="flex gap-4 list-none m-0 p-0 items-start">
  <div class="shrink-0 w-8 h-8 bg-brand-blue/10 text-blue rounded-full flex items-center justify-center mt-0.5">
    <span class="material-symbols-outlined text-[1.1rem] font-bold">check</span>
  </div>
  <p class="m-0 text-slate-600 text-base leading-relaxed font-medium">{text}</p>
</li>
