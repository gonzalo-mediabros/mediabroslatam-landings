---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<li class="item">
  <div class="icon-box">
    <span class="material-symbols-outlined">check</span>
  </div>
  <p class="item-text">{text}</p>
</li>

<style>
  .item {
    display: flex;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: flex-start;
  }

  .icon-box {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    background: rgba(20, 139, 239, 0.1);
    color: var(--primary);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.1rem;
  }

  .icon-box span {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .item-text {
    margin: 0;
    color: var(--slate-600);
    font-size: 1rem;
    line-height: 1.6;
    font-weight: 500;
  }
</style>
