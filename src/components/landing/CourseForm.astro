---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Acceder al curso gratuito",
  description = "Completa tus datos para empezar ahora mismo y recibir la guía estratégica de generación de demanda."
} = Astro.props;

const SCRIPT_URL = import.meta.env.PUBLIC_SCRIPT_URL;
const API_KEY = import.meta.env.PUBLIC_SCRIPT_API_KEY;
---

<div class="bg-white p-12 rounded-lg border border-slate-100 shadow-premium">
  <div>
    <h3 class="text-2xl font-extrabold text-navy mb-2">{title}</h3>
    <p class="text-slate-500 mb-10 text-base leading-relaxed">{description}</p>
  </div>

  <form id="course-form" data-url={SCRIPT_URL} data-apikey={API_KEY} class="contents">
    <div class="grid grid-cols-2 gap-4 max-sm:grid-cols-1">
      <div class="flex flex-col gap-1">
        <label for="name" class="text-xs font-extrabold text-slate-400 uppercase tracking-wide ml-1">Nombre</label>
        <input type="text" id="name" name="name" required placeholder="Tu nombre" class="bg-slate-50 border border-slate-200 p-4 rounded-md font-[inherit] text-base transition-all duration-200 focus:outline-none focus:border-brand-blue focus:bg-white focus:ring-4 focus:ring-brand-blue/10" />
      </div>
      <div class="flex flex-col gap-1">
        <label for="email" class="text-xs font-extrabold text-slate-400 uppercase tracking-wide ml-1">Email</label>
        <input type="email" id="email" name="email" required placeholder="tu@empresa.com" class="bg-slate-50 border border-slate-200 p-4 rounded-md font-[inherit] text-base transition-all duration-200 focus:outline-none focus:border-brand-blue focus:bg-white focus:ring-4 focus:ring-brand-blue/10" />
      </div>
      <div class="flex flex-col gap-1">
        <label for="company" class="text-xs font-extrabold text-slate-400 uppercase tracking-wide ml-1">Empresa</label>
        <input type="text" id="company" name="company" required placeholder="Nombre de empresa" class="bg-slate-50 border border-slate-200 p-4 rounded-md font-[inherit] text-base transition-all duration-200 focus:outline-none focus:border-brand-blue focus:bg-white focus:ring-4 focus:ring-brand-blue/10" />
      </div>
      <div class="flex flex-col gap-1">
        <label for="position" class="text-xs font-extrabold text-slate-400 uppercase tracking-wide ml-1">Cargo</label>
        <input type="text" id="position" name="position" required placeholder="Ej. Director Comercial" class="bg-slate-50 border border-slate-200 p-4 rounded-md font-[inherit] text-base transition-all duration-200 focus:outline-none focus:border-brand-blue focus:bg-white focus:ring-4 focus:ring-brand-blue/10" />
      </div>
    </div>

    <button type="submit" class="w-full mt-8 bg-blue text-white py-5 rounded-md font-display font-extrabold text-xl border-none cursor-pointer transition-transform duration-200 uppercase shadow-[0_8px_16px_rgba(20,139,239,0.2)] hover:scale-[1.02] hover:brightness-110">
      Acceder al curso gratuito
    </button>

    <p class="flex items-center justify-center gap-1 text-xs text-slate-400 mt-4">
      <span class="material-symbols-outlined text-sm">lock</span>
      Tus datos están seguros y no enviamos spam.
    </p>
  </form>

  <div id="form-feedback" class="hidden">
    <div class="hidden success-msg text-center p-8 font-bold text-emerald-500">
       <span class="material-symbols-outlined">check_circle</span>
       <p>¡Acceso concedido! Revisa tu email para comenzar.</p>
    </div>
    <div class="hidden error-msg text-center p-8 font-bold text-red-500">
       <span class="material-symbols-outlined">error</span>
       <p>Hubo un error. Por favor reintenta.</p>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById("course-form") as HTMLFormElement;
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.innerText;
      submitBtn.disabled = true;
      submitBtn.innerText = "Preparando acceso...";

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      const SCRIPT_URL = form.dataset.url;

      try {
        if (!SCRIPT_URL) throw new Error("API URL missing");
        await fetch(SCRIPT_URL, {
          method: "POST",
          mode: "no-cors",
          body: JSON.stringify(data),
        });
        form.style.display = "none";
        document.getElementById("form-feedback")?.classList.remove("hidden");
        document.querySelector(".success-msg")?.classList.remove("hidden");
      } catch (err) {
        console.error(err);
        submitBtn.disabled = false;
        submitBtn.innerText = "Error - Reintentar";
      }
    });
  }
</script>
