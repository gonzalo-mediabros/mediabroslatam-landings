---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Acceder al curso gratuito", 
  description = "Completa tus datos para empezar ahora mismo y recibir la guía estratégica de generación de demanda." 
} = Astro.props;

const SCRIPT_URL = import.meta.env.PUBLIC_SCRIPT_URL;
const API_KEY = import.meta.env.PUBLIC_SCRIPT_API_KEY;
---

<div class="form-card">
  <div class="header">
    <h3 class="title">{title}</h3>
    <p class="desc">{description}</p>
  </div>

  <form id="course-form" data-url={SCRIPT_URL} data-apikey={API_KEY}>
    <div class="grid">
      <div class="group">
        <label for="name">Nombre</label>
        <input type="text" id="name" name="name" required placeholder="Tu nombre" />
      </div>
      <div class="group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="tu@empresa.com" />
      </div>
      <div class="group">
        <label for="company">Empresa</label>
        <input type="text" id="company" name="company" required placeholder="Nombre de empresa" />
      </div>
      <div class="group">
        <label for="position">Cargo</label>
        <input type="text" id="position" name="position" required placeholder="Ej. Director Comercial" />
      </div>
    </div>

    <button type="submit" class="submit-btn">
      Acceder al curso gratuito
    </button>

    <p class="secure-note">
      <span class="material-symbols-outlined">lock</span>
      Tus datos están seguros y no enviamos spam.
    </p>
  </form>

  <div id="form-feedback" class="hidden">
    <div class="success-msg hidden">
       <span class="material-symbols-outlined">check_circle</span>
       <p>¡Acceso concedido! Revisa tu email para comenzar.</p>
    </div>
    <div class="error-msg hidden">
       <span class="material-symbols-outlined">error</span>
       <p>Hubo un error. Por favor reintenta.</p>
    </div>
  </div>
</div>

<style>
  .form-card {
    background: var(--white);
    padding: 3rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--slate-100);
    box-shadow: var(--shadow-premium);
  }

  .title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 0.5rem;
  }

  .desc {
    color: var(--slate-500);
    margin-bottom: 2.5rem;
    font-size: 1rem;
    line-height: 1.6;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
  }

  .group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  label {
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--slate-400);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-left: 0.25rem;
  }

  input {
    background: var(--slate-50);
    border: 1px solid var(--slate-200);
    padding: 1rem;
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  input:focus {
    outline: none;
    border-color: var(--primary);
    background: var(--white);
    box-shadow: 0 0 0 4px rgba(20, 139, 239, 0.1);
  }

  .submit-btn {
    width: 100%;
    margin-top: 2rem;
    background: var(--primary);
    color: var(--white);
    padding: 1.25rem;
    border-radius: var(--radius-md);
    font-family: "Red Hat Display", sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    border: none;
    cursor: pointer;
    transition: transform 0.2s ease;
    text-transform: uppercase;
    box-shadow: 0 8px 16px rgba(20, 139, 239, 0.2);
  }

  .submit-btn:hover {
    transform: scale(1.02);
    filter: brightness(1.1);
  }

  .secure-note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: var(--slate-400);
    margin-top: 1rem;
  }

  .secure-note span { font-size: 0.875rem; }

  .hidden { display: none; }

  .success-msg, .error-msg {
    text-align: center;
    padding: 2rem;
    font-weight: 700;
  }

  .success-msg { color: #10b981; }
  .error-msg { color: #ef4444; }
</style>

<script>
  const form = document.getElementById("course-form") as HTMLFormElement;
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.innerText;
      submitBtn.disabled = true;
      submitBtn.innerText = "Preparando acceso...";

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      const SCRIPT_URL = form.dataset.url;

      try {
        if (!SCRIPT_URL) throw new Error("API URL missing");
        await fetch(SCRIPT_URL, {
          method: "POST",
          mode: "no-cors",
          body: JSON.stringify(data),
        });
        form.style.display = "none";
        document.getElementById("form-feedback")?.classList.remove("hidden");
        document.querySelector(".success-msg")?.classList.remove("hidden");
      } catch (err) {
        console.error(err);
        submitBtn.disabled = false;
        submitBtn.innerText = "Error - Reintentar";
      }
    });
  }
</script>
