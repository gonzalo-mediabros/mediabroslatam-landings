---
interface Props {
  year?: number;
  brand?: string;
}
const { year = new Date().getFullYear(), brand = "Mediabros" } = Astro.props;
---

<footer class="bg-white border-t border-slate-100 py-8">
  <m-container>
    <m-row>
      <div class="flex flex-col items-center gap-4 text-center md:flex-row md:justify-between md:text-left">
        <img
          src={`${import.meta.env.BASE_URL}logo.svg`}
          alt={brand}
          class="h-8 w-auto grayscale opacity-60"
        />
        <p class="m-0 text-sm text-text-muted">
          &copy; {year}
          {brand}. Todos los derechos reservados.
        </p>
      </div>
    </m-row>
    <m-row>
      <p class="m-0 text-sm text-text-muted">
        This site is not part of the Meta website or Meta Inc. Additionally,
        this site is NOT endorsed by Meta in any way. META is a trademark of
        META, Inc.
      </p>
    </m-row>
  </m-container>
</footer>
