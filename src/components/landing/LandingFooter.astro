---
interface Props {
  year?: number;
  brand?: string;
}
const { year = new Date().getFullYear(), brand = "Mediabros" } = Astro.props;
---

<footer class="bg-white border-t border-slate-100 py-12">
  <m-container>
    <m-row class="flex-col md:flex-row items-center justify-between gap-8">
      <!-- col 1: Logo -->
      <m-col class="flex-none w-auto items-center md:items-start">
        <img
          src={`${import.meta.env.BASE_URL}logo.svg`}
          alt={brand}
          class="h-10 w-auto grayscale opacity-50"
        />
      </m-col>
      <!-- col 2: Copyright -->
      <m-col class="items-center">
        <p class="m-0 text-[0.75rem] text-text-muted text-center">
          &copy; {year} mediabroslatam.com. Todos los derechos reservados.
        </p>
      </m-col>
      <!-- col 3: Meta legal -->
      <m-col class="items-center md:items-end">
        <p class="m-0 text-[0.65rem] leading-relaxed text-text-muted text-center md:text-right max-w-full md:max-w-[280px]">
          This site is not part of the Meta website or Meta Inc. Additionally,
          this site is NOT endorsed by Meta in any way. META is a trademark of META, Inc.
        </p>
      </m-col>
    </m-row>
  </m-container>
</footer>
