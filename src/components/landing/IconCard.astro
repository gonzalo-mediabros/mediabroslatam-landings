---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="card">
  <div class="icon-box">
    <span class="material-symbols-outlined">{icon}</span>
  </div>
  <h4 class="card-title">{title}</h4>
  <p class="card-text">{description}</p>
</div>

<style>
  .card {
    background: var(--white);
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--slate-100);
    box-shadow: var(--shadow-card);
    transition: all var(--transition-base);
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .card:hover {
    box-shadow: var(--shadow-card-hover), 0 0 0 1px rgba(20, 139, 239, 0.1);
    transform: translateY(-6px);
    border-color: transparent;
  }

  .icon-box {
    width: 3.5rem;
    height: 3.5rem;
    background: rgba(20, 139, 239, 0.08);
    color: var(--primary);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: all var(--transition-base);
  }

  .card:hover .icon-box {
    background: rgba(20, 139, 239, 0.16);
    transform: scale(1.05);
  }

  .icon-box span {
    font-size: 1.75rem;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .card-text {
    color: var(--slate-500);
    line-height: 1.6;
    margin: 0;
  }
</style>
