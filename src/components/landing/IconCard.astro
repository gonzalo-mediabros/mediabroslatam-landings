---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="group bg-white p-8 rounded-lg border border-slate-100 shadow-card transition-all duration-[--transition-base] h-full flex flex-col justify-start hover:shadow-card-hover hover:ring-1 hover:ring-brand-blue/10 hover:-translate-y-1.5 hover:border-transparent">
  <div class="w-14 h-14 bg-brand-blue/8 text-blue rounded-md flex items-center justify-center mb-6 transition-all duration-[--transition-base] group-hover:bg-brand-blue/15 group-hover:scale-105">
    <span class="material-symbols-outlined text-[1.75rem]">{icon}</span>
  </div>
  <h4 class="text-xl font-extrabold text-navy mb-3 leading-snug">{title}</h4>
  <p class="text-slate-500 leading-relaxed m-0">{description}</p>
</div>
