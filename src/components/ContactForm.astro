---
const {
  title = "Acceder al curso",
  buttonText = "Acceder al curso gratuito",
  source = "Landing General",
  showTitle = true,
} = Astro.props;

const SCRIPT_URL = import.meta.env.PUBLIC_SCRIPT_URL;
const API_KEY = import.meta.env.PUBLIC_SCRIPT_API_KEY;
---

<div class="w-full">
  {showTitle && <h3 class="text-3xl font-black mb-8">{title}</h3>}

  <form
    id="contact-form"
    data-url={SCRIPT_URL}
    data-apikey={API_KEY}
    data-source={source}
    class="flex flex-col gap-6"
  >
    <div class="flex flex-col gap-2.5">
      <label for="name" class="block font-display text-sm font-bold text-slate-600 uppercase tracking-wide">Nombre Completo</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        placeholder="Tu nombre"
        class="w-full py-4.5 px-6 border-2 border-slate-100 rounded-md font-[inherit] text-base transition-all duration-300 bg-slate-50 text-navy focus:outline-none focus:border-brand-blue focus:bg-white focus:ring-4 focus:ring-brand-blue/15"
      />
    </div>

    <div class="flex flex-col gap-2.5">
      <label for="email" class="block font-display text-sm font-bold text-slate-600 uppercase tracking-wide">Correo Corporativo</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="ejemplo@empresa.com"
        class="w-full py-4.5 px-6 border-2 border-slate-100 rounded-md font-[inherit] text-base transition-all duration-300 bg-slate-50 text-navy focus:outline-none focus:border-brand-blue focus:bg-white focus:ring-4 focus:ring-brand-blue/15"
      />
    </div>

    <div class="flex flex-col gap-2.5">
      <label for="phone" class="block font-display text-sm font-bold text-slate-600 uppercase tracking-wide">Teléfono / WhatsApp</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        placeholder="+54 9 11 ..."
        class="w-full py-4.5 px-6 border-2 border-slate-100 rounded-md font-[inherit] text-base transition-all duration-300 bg-slate-50 text-navy focus:outline-none focus:border-brand-blue focus:bg-white focus:ring-4 focus:ring-brand-blue/15"
      />
    </div>

    <div class="flex flex-col gap-2.5">
      <label for="company" class="block font-display text-sm font-bold text-slate-600 uppercase tracking-wide">Sitio Web de la Empresa</label>
      <input
        type="text"
        id="company"
        name="company"
        placeholder="www.tuempresa.com"
        class="w-full py-4.5 px-6 border-2 border-slate-100 rounded-md font-[inherit] text-base transition-all duration-300 bg-slate-50 text-navy focus:outline-none focus:border-brand-blue focus:bg-white focus:ring-4 focus:ring-brand-blue/15"
      />
    </div>

    <!-- Honeypot field (hidden) -->
    <div class="sr-only">
      <label for="website">Website</label>
      <input
        type="text"
        id="website"
        name="website"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    <button type="submit" class="w-full bg-blue text-white py-5 border-none rounded-full font-display text-lg font-extrabold cursor-pointer transition-all duration-300 mt-6 shadow-[0_12px_24px_-5px_rgba(21,139,239,0.4)] hover:bg-navy hover:-translate-y-0.5 hover:shadow-[0_15px_30px_-10px_rgba(31,33,61,0.3)]">
      {buttonText}
    </button>
  </form>

  <div id="form-feedback" class="hidden">
    <div class="hidden success-msg bg-green-50 text-green-800 p-6 rounded-md mt-8 font-bold border border-green-200 items-center gap-4 shadow-sm">
      <span class="material-icons">check_circle</span>
      <p>¡Listo! Te contactaremos a la brevedad.</p>
    </div>
    <div class="hidden error-msg bg-red-50 text-red-800 p-6 rounded-md mt-8 font-bold border border-red-200 items-center gap-4 shadow-sm">
      <span class="material-icons">error</span>
      <p>Error al enviar. Intenta de nuevo.</p>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const feedback = document.getElementById("form-feedback");
  const successMsg = feedback?.querySelector(".success-msg");
  const errorMsg = feedback?.querySelector(".error-msg");

  if (form) {
    const SCRIPT_URL = form.dataset.url;
    const API_KEY = form.dataset.apikey;
    const SOURCE = form.dataset.source;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement;
      if (submitBtn) {
        submitBtn.disabled = true;
        const originalText = submitBtn.innerText;
        submitBtn.innerText = "Enviando...";
      }

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      data.origin = window.location.origin;
      data.api_key = API_KEY || "";
      data.source_page = SOURCE || window.location.pathname;

      try {
        if (!SCRIPT_URL) throw new Error("Script URL not configured");

        await fetch(SCRIPT_URL, {
          method: "POST",
          mode: "no-cors",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        form.style.display = "none";
        feedback?.classList.replace("hidden", "block");
        successMsg?.classList.replace("hidden", "flex");
      } catch (error) {
        console.error("Error:", error);
        feedback?.classList.replace("hidden", "block");
        errorMsg?.classList.replace("hidden", "flex");
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerText = "Reintentar envío";
        }
      }
    });
  }
</script>
