---
/* src/components/ContactForm.astro - RECONSTRUCCIÓN TOTAL ZERO-BASE */
import styles from "./ContactForm.module.css";

const {
  title = "Acceder al curso",
  buttonText = "Acceder al curso gratuito",
  source = "Landing General",
  showTitle = true,
} = Astro.props;

const SCRIPT_URL = import.meta.env.PUBLIC_SCRIPT_URL;
const API_KEY = import.meta.env.PUBLIC_SCRIPT_API_KEY;
---

<div class={styles.contactFormContainer}>
  {showTitle && <h3 class="text-3xl font-black mb-8">{title}</h3>}

  <form
    id="contact-form"
    data-url={SCRIPT_URL}
    data-apikey={API_KEY}
    data-source={source}
    class={styles.mzForm}
  >
    <div class={styles.formGroup}>
      <label for="name" class={styles.label}>Nombre Completo</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        placeholder="Tu nombre"
        class={styles.input}
      />
    </div>

    <div class={styles.formGroup}>
      <label for="email" class={styles.label}>Correo Corporativo</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="ejemplo@empresa.com"
        class={styles.input}
      />
    </div>

    <div class={styles.formGroup}>
      <label for="phone" class={styles.label}>Teléfono / WhatsApp</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        placeholder="+54 9 11 ..."
        class={styles.input}
      />
    </div>

    <div class={styles.formGroup}>
      <label for="company" class={styles.label}>Sitio Web de la Empresa</label>
      <input
        type="text"
        id="company"
        name="company"
        placeholder="www.tuempresa.com"
        class={styles.input}
      />
    </div>

    <!-- Honeypot field (hidden) -->
    <div class={styles.srOnly}>
      <label for="website">Website</label>
      <input
        type="text"
        id="website"
        name="website"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    <button type="submit" class={styles.btnPrimary}>
      {buttonText}
    </button>
  </form>

  <div id="form-feedback" class="hidden">
    <div class={`${styles.successMessage} hidden success-msg`}>
      <span class="material-icons">check_circle</span>
      <p>¡Listo! Te contactaremos a la brevedad.</p>
    </div>
    <div class={`${styles.errorMessage} hidden error-msg`}>
      <span class="material-icons">error</span>
      <p>Error al enviar. Intenta de nuevo.</p>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const feedback = document.getElementById("form-feedback");
  const successMsg = feedback?.querySelector(".success-msg");
  const errorMsg = feedback?.querySelector(".error-msg");

  if (form) {
    const SCRIPT_URL = form.dataset.url;
    const API_KEY = form.dataset.apikey;
    const SOURCE = form.dataset.source;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement;
      if (submitBtn) {
        submitBtn.disabled = true;
        const originalText = submitBtn.innerText;
        submitBtn.innerText = "Enviando...";
      }

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      data.origin = window.location.origin;
      data.api_key = API_KEY || "";
      data.source_page = SOURCE || window.location.pathname;

      try {
        if (!SCRIPT_URL) throw new Error("Script URL not configured");

        await fetch(SCRIPT_URL, {
          method: "POST",
          mode: "no-cors",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        form.style.display = "none";
        if (feedback) feedback.classList.remove("hidden");
        if (successMsg) successMsg.classList.remove("hidden");
      } catch (error) {
        console.error("Error:", error);
        if (feedback) feedback.classList.remove("hidden");
        if (errorMsg) errorMsg.classList.remove("hidden");
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerText = "Reintentar envío";
        }
      }
    });
  }
</script>
