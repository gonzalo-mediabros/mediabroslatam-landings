---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  image?: string; // Para compatibilidad
  canonicalURL?: string;
  noindex?: boolean;
  ogType?: string;
}

// MASTER SWITCH: Si es true, fuerza noindex en todo el sitio
const GLOBAL_NOINDEX = true;

const {
  title,
  description,
  ogImage,
  image,
  noindex = true,
  ogType = "website",
  canonicalURL = Astro.url.href,
} = Astro.props;

// Prioridad: ogImage > image > default
const finalImage = ogImage || image || "assets/og-image.jpg";
const socialImage = new URL(finalImage, Astro.site || Astro.url).href;

const shouldNoIndex = GLOBAL_NOINDEX || noindex;

const { pathname } = Astro.url;

// Función para normalizar y comparar rutas
const isActive = (path: string) => {
  const normalizedPath = path.endsWith("/") ? path : `${path}/`;
  const normalizedCurrent = pathname.endsWith("/") ? pathname : `${pathname}/`;
  return normalizedCurrent === normalizedPath;
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    {shouldNoIndex && <meta name="robots" content="noindex,nofollow" />}
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={Astro.url.href} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <!-- Google Material Icons & Symbols -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/icon?family=Material+Icons"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav
      class="dev-nav flex gap-8 top-0 left-0 z-1000 bg-brand-graybg w-full px-8 py-3 text-sm font-medium"
    >
      <span class="text-blue">Menu temporal de desarrollo</span>
      <a
        href={import.meta.env.BASE_URL}
        class={isActive(import.meta.env.BASE_URL)
          ? "underline decoration-2 underline-offset-4 text-blue"
          : "text-gray-600 hover:text-blue transition-colors"}>Curso</a
      >
      <a
        href={`${import.meta.env.BASE_URL}index2`}
        class={isActive(`${import.meta.env.BASE_URL}index2`)
          ? "underline decoration-2 underline-offset-4 text-blue"
          : "text-gray-600 hover:text-blue transition-colors"}>Curso v2</a
      >
      <a
        href={`${import.meta.env.BASE_URL}guia`}
        class={isActive(`${import.meta.env.BASE_URL}guia`)
          ? "underline decoration-2 underline-offset-4 text-blue"
          : "text-gray-600 hover:text-blue transition-colors"}>Guía</a
      >
      <a
        href={`${import.meta.env.BASE_URL}auditoria`}
        class={isActive(`${import.meta.env.BASE_URL}auditoria`)
          ? "underline decoration-2 underline-offset-4 text-blue"
          : "text-gray-600 hover:text-blue transition-colors"}>Auditoría</a
      >
      <a
        href={`${import.meta.env.BASE_URL}diagnostico`}
        class={isActive(`${import.meta.env.BASE_URL}diagnostico`)
          ? "underline decoration-2 underline-offset-4 text-blue"
          : "text-gray-600 hover:text-blue transition-colors"}>Diagnóstico</a
      >
    </nav>

    <slot />
  </body>
</html>
