---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import IconCard from "../components/landing/IconCard.astro";
import CheckItem from "../components/landing/CheckItem.astro";
import CourseForm from "../components/landing/CourseForm.astro";
import styles from "./index.module.css";

const title = "Generación de Leads B2B - Curso Online Gratuito | Mediabros";
const description =
  "Descubre cómo multiplicar tus leads calificados y profesionalizar tu estrategia de marketing digital en tan solo 45 minutos.";

const logoUrl = `${import.meta.env.BASE_URL}logo.svg`;
const heroImgUrl = `${import.meta.env.BASE_URL}cursos.png`;
const badgesImgUrl = `${import.meta.env.BASE_URL}badges.jpg`;
const formulaImgUrl = `${import.meta.env.BASE_URL}iconos.png`;
---

<Layout title={title} description={description}>
  <main>
    <!-- HERO SECTION -->
    <div class={styles.hero}>
      <m-container>
        <!-- NAV ROW -->
        <m-row>
          <m-col>
            <nav class={styles.hero_nav}>
              <img src={logoUrl} alt="Mediabros" class={styles.logo_inv} />
              <Button text="Acceder gratis" href="#registro" />
            </nav>
          </m-col>
        </m-row>

        <!-- MAIN HERO ROW (2 Columns) -->
        <m-row flex class={styles.hero_row}>
          <m-col>
            <span class={styles.hero_badge}>Exclusivo para B2B</span>
            <h1>Cómo multiplicar tus <span>leads calificados</span></h1>
            <p>
              Estrategias avanzadas para transformar tu presencia digital en un
              motor de generación de demanda real. Sin fórmulas mágicas, solo
              resultados.
            </p>
            <m-row flex>
              <m-col>
                <Button text="Ver video introductorio" href="#video">
                  <span slot="before" class="material-symbols-outlined"
                    >play_circle</span
                  >
                </Button>
              </m-col>
            </m-row>
          </m-col>

          <m-col>
            <figure class={styles.hero_media}>
              <img src={heroImgUrl} alt="Dashboard" />
            </figure>
          </m-col>
        </m-row>
      </m-container>
    </div>

    <!-- FORM ROW -->
    <section>
      <m-container>
        <m-row>
          <m-col>
            <CourseForm />
          </m-col>
        </m-row>
      </m-container>
    </section>

    <!-- FORMULA -->
    <section class={styles.formula}>
      <m-container>
        <m-row>
          <m-col>
            <p>Formula del éxito</p>
            <img src={formulaImgUrl} alt="formula" />
          </m-col>
        </m-row>
      </m-container>
    </section>

    <!-- AGITADOR / PROBLEMA -->
    <section class={styles.agitador}>
      <m-container>
        <m-row>
          <m-col>
            <h2>
              Deja de perder clientes y dinero <br />
              <span class="text-slate-400">sin rumbo ni estrategia.</span>
            </h2>
            <h3>
              Tu empresa no necesita más <span>likes</span>. Necesita
              oportunidades reales de negocio.
            </h3>
            <p>
              Si hoy tenés un sitio web, invertís en campañas o hacés algo de
              marketing digital, pero los resultados no llegan — o llegan mal —
              probablemente el problema no sea la inversión, sino la falta de un
              plan claro.
            </p>
          </m-col>
        </m-row>
      </m-container>
    </section>

    <!-- SOBRE EL CURSO -->
    <section class={styles.sobre}>
      <m-container>
        <m-row>
          <m-col>
            <h2>¿Sobre qué trata el curso?</h2>
            <p>
              Este curso online gratuito te permite <strong
                >descubrir cómo generar leads de calidad</strong
              > para tu empresa en tiempo récord con una sólida estrategia de marketing
              digital y está diseñado como una guía práctica para empresas que buscan
              profesionalizar su generación de demanda.
            </p>
            <p>
              En tan solo <strong>45 minutos</strong>, este entrenamiento
              gratuito ofrece una visión clara sobre el universo del marketing
              digital, los diferentes tipos de proveedores, cómo hacer un
              diagnóstico inicial del estado actual de tu empresa, y cómo
              diseñar una estrategia de generación de leads efectiva.
            </p>
            <blockquote class={styles.sobre_quote}>
              <p>
                "Está especialmente dirigido a decisores en empresas que quieren
                dejar de improvisar y comenzar a tomar decisiones basadas en
                resultados medibles."
              </p>
            </blockquote>
          </m-col>
        </m-row>
      </m-container>
    </section>

    <!-- GRID INFORMATIVO -->
    <section class={styles.info_grid}>
      <m-container>
        <!-- 1 Fila, 2 Columnas -->
        <m-row flex>
          <m-col>
            <h3>¿Para quién es este curso?</h3>
            <ul class={styles.column_list}>
              <CheckItem
                text="Dueños de empresas con un producto consolidado o un servicio para vender."
              />
              <CheckItem
                text="Responsables de marketing que desean desarrollar su estrategia."
              />
              <CheckItem
                text="Gerentes comerciales que desean incrementar su facturación."
              />
              <CheckItem
                text="Personas que están buscando el crecimiento sustentable de su empresa."
              />
              <CheckItem
                text="Personas que están buscando mejorar sus habilidades de marketing."
              />
            </ul>
          </m-col>

          <m-col>
            <h3>¿Qué vas a aprender?</h3>
            <ul class={styles.column_list}>
              <CheckItem text="Cómo crear una estrategia digital real." />
              <CheckItem text="En que medios y cómo invertir." />
              <CheckItem
                text="Cómo evitar errores comunes que frenan resultados."
              />
              <CheckItem text="Qué tipo de proveedor o equipo te conviene." />
              <CheckItem text="Ejemplos reales con resultados medibles." />
            </ul>
          </m-col>
        </m-row>
      </m-container>
    </section>

    <!-- PROPUESTAS DE VALOR -->
    <section class={styles.props}>
      <m-container>
        <m-row flex>
          <m-col>
            <IconCard
              icon="psychology"
              title="Diagnóstico Guiado"
              description="Aprenderás a identificar errores comunes."
            />
          </m-col>
          <m-col>
            <IconCard
              icon="map"
              title="Claridad estratégica"
              description="Descubrirás qué canales son los adecuados."
            />
          </m-col>
          <m-col>
            <IconCard
              icon="fact_check"
              title="Casos reales"
              description="Casos concretos en sectores logísticos y construcción."
            />
          </m-col>
          <m-col>
            <IconCard
              icon="bolt"
              title="Acción inmediata"
              description="Llamado a la acción claro para avanzar con solidez."
            />
          </m-col>
        </m-row>
      </m-container>
    </section>

    <!-- CTA FINAL -->
    <section class={styles.cta_final}>
      <div class={`${styles.cta_pattern} gridPattern`}></div>
      <m-container>
        <m-row>
          <m-col>
            <h2>¿Listo para transformar tu generación de leads?</h2>
            <p>
              No dejes que otro trimestre pase con un pipeline vacío. Únete a
              los +500 profesionales que ya están usando esta metodología.
            </p>
            <m-row flex>
              <m-col>
                <Button text="Empezar curso ahora" href="#registro" />
              </m-col>
            </m-row>

            <div class={styles.social_proof}>
              <div class={styles.avatars}>
                <img
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuBE5tUvozgyAKhXsq-KaEZB_U3kmQB3Q5u-blFNkBl5Ww4qdbCZPCWENiMQJRa0yL96PLTwjKZ6IzG7BSjQQ8jCaMKx0so8wQLnD9GN8nef6tqy95pVFpkXZUC1uW7jqkfZUrPKgZx_LnjPuKtFjjxWxGs7BDmgyYe67gfbNIww-9riptPF6FsYx3u80Zfs02S7s_9ZGil1CX3rxlDFrLAKMOEKRjkwWl0PwVP6PdxnCD7ne9124JSIdSHW1_qHX6B7QwY_oYMFtg"
                  alt="User"
                  class={styles.avatar}
                />
                <img
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuA3vtR2OFdvfn_5Q39sbihqUR80238OqIW2nSxFt5rYuiQZRFD563vmHBxP6oEmZbm0ixhIVqsVq_Y91ArvC2rtQthpp4v65nfymS778yigku1Fc9bVHwkyvL1Zu7FGK3oYnLouJ3OEOdYVGGir_qxWHWk4BLJbDpoiYY5WkzjcB53p56F70jgBd5s-Lz-QE5RlyoLDxOKUbuv2kBa7W8-HeBGVEU4GaXQxBa2mJb8V3ehyOCgOWYWVl-H-o39njRvRIZnehKJ3zQ"
                  alt="User"
                  class={styles.avatar}
                />
                <img
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuCv7advdcPnDpsqn2E82mxCXq1eCi06sBEKoLL8gN1ko3F9iYn1LQ5vj56ZKPoO7Rl0VaNYTXcYKI1lETGhHA5F15ohBBpjwMJ4ZRO5CYNh2bp1VkgRysKFxXjQ_vLWCPdOPus4mDep4YT0JEvS0rhetv07xl2tbYHkIFp_LHmoKbuRo9RK5YQOZUJQlq4qf3dtNPJJOtebYEwPvkfT9_GwnpT1yDNSu4OJvyMZnBpQ9MxPspZqlr48hRpwkBmJITByCYHsNvu8Rw"
                  alt="User"
                  class={styles.avatar}
                />
              </div>
              <p>Únete a <span>500+</span> líderes B2B</p>
            </div>
          </m-col>
        </m-row>
      </m-container>
    </section>

    <!-- FOOTER -->
    <footer class={styles.footer}>
      <m-container>
        <m-row>
          <m-col>
            <div class={styles.footer_inner}>
              <img src={logoUrl} alt="Mediabros" />
              <p>© 2026 mediabroslatam.com Todos los derechos reservados.</p>
            </div>
          </m-col>
        </m-row>
      </m-container>
    </footer>
  </main>
</Layout>
