---
/* s:\Proyectos\01_Clientes\Mediabros\Mediabros\Landings\src\pages\index.astro - FINAL JEFE VERSION */
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import styles from "./index.module.css";

const title = "Curso Online Gratuito - Multiplica tus Leads | MediaBros";
const description =
  "De la confusión a la claridad en tan solo 45 minutos. Te contamos como aplicarlo a tu empresa.";
---

<Layout title={title} description={description}>
  <main>
    <!-- HERO SECTION (NAVY) -->
    <section class={styles.hero}>
      <div class="container">
        <div class={styles.heroContent}>
          <div>
            <img
              src={`${import.meta.env.BASE_URL}logo.svg`}
              alt="Mediabros"
              style="height: 50px; margin-bottom: 3.5rem; filter: brightness(0) invert(1);"
            />
            <h1 class={styles.titleLg}>
              Cómo multiplicar tus leads calificados
            </h1>
            <p class={styles.subtitleLg}>
              De la confusión a la claridad en tan solo 45 minutos. Te contamos
              cómo aplicarlo a tu empresa para profesionalizar tu generación de
              demanda.
            </p>

            <div class={styles.heroVisuals}>
              <!-- Imagen del Curso (Muy importante en Hero) -->
              <img
                src={`${import.meta.env.BASE_URL}cursos.png`}
                alt="MediaBros Cursos"
                class={styles.cursoImg}
              />

              <!-- Trust Badges -->
              <div class={styles.trustRow}>
                <div class={styles.chipHero}>
                  <span class="material-icons">paid</span> Gratuito
                </div>
                <div class={styles.chipHero}>
                  <span class="material-icons">verified</span> Validado
                </div>
                <div class={styles.chipHero}>
                  <span class="material-icons">security</span> Asegurado
                </div>
              </div>

              <!-- Iconos (Trust Row en Hero) -->
              <img
                src={`${import.meta.env.BASE_URL}iconos.png`}
                alt="Toolset Mediabros"
                class={styles.iconosHero}
              />
            </div>
          </div>

          <div class={styles.formContainer}>
            <div class="text-center mb-10">
              <span class="chip">Curso online gratuito</span>
              <div
                class="flex items-center justify-center gap-2 font-bold mt-4"
                style="color: var(--blue)"
              >
                <span class="material-icons">schedule</span>
                <span>Duración: 45 min</span>
              </div>
            </div>

            <ContactForm
              title="Acceder al curso"
              buttonText="Acceder al curso gratuito"
              source="Cursos - Hero Final"
              showTitle={false}
            />
          </div>
        </div>
      </div>
    </section>

    <!-- VISION SECTION (WHITE BASE PARA BADGES.JPG) -->
    <section class={styles.whiteSection}>
      <div class="container">
        <div class={styles.visionGrid}>
          <span class="chip">Visión Estratégica</span>
          <h2>
            Una oportunidad única para desarrollar tu estrategia de marketing
            digital
          </h2>

          <div class={styles.quoteBlock}>
            Tu empresa no necesita más likes. <br />
            Necesita oportunidades reales de negocio.
          </div>

          <p class="text-xl text-slate-600 leading-relaxed mb-12">
            Si hoy tenés un sitio web, invertís en campañas o hacés algo de
            marketing digital, pero los resultados no llegan — o llegan mal —
            probablemente el problema no sea la inversión, sino la falta de un
            plan claro.
          </p>

          <!-- Badges Section (Integrado en fondo blanco) -->
          <img
            src={`${import.meta.env.BASE_URL}badges.jpg`}
            alt="Trusted Partners"
            class={styles.badgesImg}
          />
        </div>
      </div>
    </section>

    <!-- MODULES & CUSOS.WEBP (SLATE) -->
    <section class={styles.modulesSection}>
      <div class="container">
        <div class="text-center mb-16">
          <h2 class="text-4xl">¿Sobre qué trata el curso?</h2>
          <p class="text-xl text-slate-600 mt-6 max-w-3xl mx-auto">
            Este curso online gratuito te permite descubrir cómo generar leads
            de calidad para tu empresa en tiempo récord. Diseñado como una guía
            práctica para decisores que buscan profesionalizar su generación de
            demanda. Ofrece una visión clara sobre el universo del marketing
            digital, los diferentes tipos de proveedores, cómo hacer un
            diagnóstico inicial y cómo diseñar una estrategia efectiva.
          </p>
        </div>

        <div class={styles.moduleGrid}>
          <div class={styles.moduleCard}>
            <h3 class="mb-8 flex items-center gap-3">
              <span class="material-icons" style="color: var(--blue)"
                >groups</span
              >
              ¿Para quién es este curso?
            </h3>
            <div class={styles.listRow}>
              <span>✓</span> Dueños de empresas con producto o servicio consolidado.
            </div>
            <div class={styles.listRow}>
              <span>✓</span> Responsables de marketing que desean desarrollar su estrategia.
            </div>
            <div class={styles.listRow}>
              <span>✓</span> Gerentes comerciales que desean incrementar facturación.
            </div>
            <div class={styles.listRow}>
              <span>✓</span> Buscando crecimiento sustentable de su empresa.
            </div>
            <div class={styles.listRow}>
              <span>✓</span> Mejorar sus habilidades de marketing.
            </div>
          </div>
          <div class={styles.moduleCard}>
            <h3 class="mb-8 flex items-center gap-3">
              <span class="material-icons" style="color: var(--blue)"
                >verified</span
              >
              ¿Qué vas a aprender?
            </h3>
            <div class={styles.listRow}>
              <span>✓</span> Cómo crear una estrategia digital real.
            </div>
            <div class={styles.listRow}>
              <span>✓</span> En qué medios y cómo invertir.
            </div>
            <div class={styles.listRow}>
              <span>✓</span> Evitar errores comunes que frenan resultados.
            </div>
            <div class={styles.listRow}>
              <span>✓</span> Qué tipo de proveedor o equipo te conviene.
            </div>
            <div class={styles.listRow}>
              <span>✓</span> Ejemplos reales con resultados medibles.
            </div>
          </div>
        </div>

        <!-- cusos.webp en el cuerpo -->
        <div class="text-center mt-20">
          <img
            src={`${import.meta.env.BASE_URL}cusos.webp`}
            alt="Detalles del Curso"
            class={styles.cusosWebp}
            style="margin: 0 auto;"
          />
        </div>
      </div>
    </section>

    <!-- FINAL CTA (NAVY) -->
    <section class={styles.ctaFooter}>
      <div class="container">
        <h2 class="text-5xl mb-8">
          Genera leads de calidad para tu empresa en tiempo record
        </h2>
        <p class="text-2xl opacity-70 mb-12">
          Accede al curso de MediaBros y descubre cómo elegir los canales
          adecuados y evitar errores comunes. Ideal para decisores que buscan
          resultados en el corto plazo.
        </p>
        <a href="#top" class="btn text-xl"
          >¡Accede al curso online gratuito ahora!</a
        >
      </div>
    </section>

    <footer class={styles.legalFooter}>
      <div class="container text-center">
        <img
          src={`${import.meta.env.BASE_URL}logo.svg`}
          alt="Mediabros"
          style="height: 35px; margin-bottom: 3rem; opacity: 0.5; filter: grayscale(1);"
        />
        <p class="mb-4 opacity-70 max-w-2xl mx-auto">
          This site is not part of the Meta website or Meta Inc. Additionally,
          this site is NOT endorsed by Meta in any way.
        </p>
        <p class="font-bold">© 2025 mediabroslatam.com ALL RIGHTS RESERVED.</p>
      </div>
    </footer>
  </main>
</Layout>
