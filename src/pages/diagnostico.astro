---
import Layout from "../layouts/Layout.astro";
import LeadForm from "../components/ui/LeadForm.astro";
import Chip from "../components/ui/Chip.astro";
import BenefitCard from "../components/ui/BenefitCard.astro";
import TestimonialVideoCard from "../components/ui/TestimonialVideoCard.astro";
import FaqAccordion from "../components/ui/FaqAccordion.astro";
import Footer from "../components/ui/Footer.astro";

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Sesión Estratégica Gratuita | Mediabros"
  description="Deja de perder clientes y presupuesto por falta de estrategia. De la confusión a la claridad en solo 25 minutos."
  ogImage={`${base}og/sesion-estrategica.jpg`}
  ogType="website"
>
  <main>
    <!-- ----- HERO ----- -->
    <header
      id="hero"
      class="bg-brand-dark min-h-screen flex items-center py-16 relative overflow-hidden"
    >
      <!-- Glow Decorativo -->
      <div
        class="absolute top-0 left-0 w-150 h-150 bg-brand-blue/10 rounded-full blur-[100px] -translate-y-1/2 -translate-x-1/4 pointer-events-none"
      >
      </div>

      <m-container class="relative z-10">
        <m-row class="flex-col lg:flex-row gap-12 lg:gap-16 items-center">
          <!-- Hero Content -->
          <m-col class="flex-[1.2] items-start text-white">
            <img
              src={`${base}logo.svg`}
              alt="Mediabros"
              class="h-10 mb-12 w-auto"
            />
            <div
              class="rounded-xl overflow-hidden shadow-premium border border-white/10 w-full max-w-150 mb-8 z-20 relative"
            >
              <video
                src={`${base}video.webm`}
                class="w-full object-cover aspect-4/5 sm:aspect-video"
                autoplay
                loop
                muted
                controls
                playsinline></video>
            </div>

            <Chip
              text="Sesión 1 a 1 Gratuita"
              icon="check_circle"
              class="mb-6 bg-brand-blue/10 border-brand-blue/30 text-blue-400"
            />

            <h1
              class="text-[clamp(2.5rem,3.5vw,3.5rem)] font-display font-black leading-[1.1] mb-6 tracking-tight text-white"
            >
              Sesión de diagnóstico y asesoramiento
            </h1>

            <p class="text-lg text-text-light leading-relaxed max-w-xl">
              Deja de perder clientes y presupuesto por falta de estrategia. <strong
                >De la confusión a la claridad en solo 25 minutos.</strong
              >
            </p>
          </m-col>

          <!-- Form Card -->
          <m-col class="flex-[0.8]">
            <LeadForm
              theme="dark"
              title="Agenda tu sesión"
              subtitle="Completa el formulario y nos contactamos contigo para agendar tu sesión gratuita 1 a 1 con un experto."
              buttonText="¡Quiero mi sesión!"
            >
              <div slot="footer" class="footer-item">
                <m-icon class="material-symbols-outlined">paid</m-icon>
                <span>Gratuito</span>
              </div>
              <div slot="footer" class="footer-item">
                <m-icon class="material-symbols-outlined">verified</m-icon>
                <span>Validado</span>
              </div>
              <div slot="footer" class="footer-item">
                <m-icon class="material-symbols-outlined">security</m-icon>
                <span>Asegurado</span>
              </div>
            </LeadForm>
          </m-col>
        </m-row>
      </m-container>
    </header>

    <!-- ----- AGITATION ----- -->
    <section id="agitation" class="py-20 bg-white">
      <m-container>
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="titleCapitalice text-brand-blue">Problemas comunes</p>
          <h2
            class="text-3xl lg:text-4xl font-display font-bold text-navy mb-4"
          >
            ¿Esto te suena familiar?
          </h2>
          <p class="text-lg text-slate-600">
            No sabes qué ajustar para atraer más clientes sin seguir quemando
            presupuesto.
          </p>
        </div>

        <m-row class="flex-col md:flex-row flex-wrap gap-6 lg:gap-8">
          <!-- Card 1 -->
          <m-col
            class="md:flex-[1_1_45%] bg-white rounded-xl p-8 shadow-card border border-slate-100 flex-row items-start gap-6 hover:shadow-card-hover transition-base"
          >
            <div
              class="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center text-red-500 font-display font-bold text-xl shrink-0"
            >
              1
            </div>
            <p class="text-slate-700 text-lg">
              Sientes que <strong>tu marketing digital no funciona</strong> y no entiendes
              por qué.
            </p>
          </m-col>

          <!-- Card 2 -->
          <m-col
            class="md:flex-[1_1_45%] bg-white rounded-xl p-8 shadow-card border border-slate-100 flex-row items-start gap-6 hover:shadow-card-hover transition-base"
          >
            <div
              class="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center text-red-500 font-display font-bold text-xl shrink-0"
            >
              2
            </div>
            <p class="text-slate-700 text-lg">
              Estás invirtiendo en campañas, pero <strong
                >no ves resultados concretos.</strong
              >
            </p>
          </m-col>

          <!-- Card 3 -->
          <m-col
            class="md:flex-[1_1_45%] bg-white rounded-xl p-8 shadow-card border border-slate-100 flex-row items-start gap-6 hover:shadow-card-hover transition-base"
          >
            <div
              class="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center text-red-500 font-display font-bold text-xl shrink-0"
            >
              3
            </div>
            <p class="text-slate-700 text-lg">
              Probaste varias agencias o freelancers, pero <strong
                >seguís sin generar oportunidades reales.</strong
              >
            </p>
          </m-col>

          <!-- Card 4 -->
          <m-col
            class="md:flex-[1_1_45%] bg-white rounded-xl p-8 shadow-card border border-slate-100 flex-row items-start gap-6 hover:shadow-card-hover transition-base"
          >
            <div
              class="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center text-red-500 font-display font-bold text-xl shrink-0"
            >
              4
            </div>
            <p class="text-slate-700 text-lg">
              Tu equipo está haciendo "de todo un poco", pero <strong
                >sin una estrategia clara ni foco.</strong
              >
            </p>
          </m-col>
        </m-row>

        <!-- Bridge Module -->
        <m-row class="mt-8">
          <m-col
            class="bg-brand-dark rounded-xl p-10 lg:p-14 text-center items-center text-white relative overflow-hidden shadow-premium border border-white/5 transition-all hover:shadow-card-hover"
          >
            <div
              class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10 mix-blend-overlay"
            >
            </div>

            <m-icon
              class="material-symbols-outlined text-5xl text-brand-blue mb-4 relative z-10"
              >lightbulb</m-icon
            >
            <p
              class="text-2xl lg:text-3xl font-display font-bold mb-6 leading-tight relative z-10 text-balance"
            >
              Si alguna de estas situaciones te suena familiar, necesitas
              claridad.
            </p>
            <p
              class="text-lg text-text-light leading-relaxed max-w-3xl mx-auto relative z-10"
            >
              En esta sesión 1:1, <strong class="text-white"
                >trabajaremos juntos para crear un plan accionable</strong
              > con pasos concretos que te permitirán atraer clientes con estrategia
              y seguridad.
            </p>
          </m-col>
        </m-row>
      </m-container>
    </section>

    <!-- ----- EXPECTATIONS ----- -->
    <section id="expectations" class="py-20 bg-white">
      <m-container>
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2
            class="text-3xl lg:text-4xl font-display font-bold text-navy mb-4"
          >
            ¿Qué vamos a trabajar en la sesión?
          </h2>
          <p class="text-lg text-slate-600">
            Un recorrido directo y sin rodeos hacia la escalabilidad de tus
            ventas.
          </p>
        </div>

        <m-row class="flex-col lg:flex-row flex-wrap gap-6 lg:gap-8">
          <BenefitCard
            title="Diagnóstico personalizado del estado actual"
            description="Revisamos cómo está funcionando tu marketing hoy: canales, rendimiento, inversión y coherencia estratégica."
            icon="troubleshoot"
            class="lg:flex-[1_1_45%]"
          />
          <BenefitCard
            title="Identificación de errores y oportunidades"
            description="Detectamos los puntos ciegos que te están frenando y mostramos dónde puedes mejorar para generar más oportunidades."
            icon="youtube_searched_for"
            class="lg:flex-[1_1_45%]"
          />
          <BenefitCard
            title="Plan de acción inicial"
            description="Te llevas una propuesta concreta con acciones recomendadas, plataformas sugeridas y secuencia de ejecución."
            icon="assignment_turned_in"
            class="lg:flex-[1_1_45%]"
          />
          <BenefitCard
            title="Proyección de resultados"
            description="Te mostramos escenarios reales: inversión recomendada, resultados estimados y próximos pasos según tu etapa digital."
            icon="monitoring"
            class="lg:flex-[1_1_45%]"
          />
        </m-row>
      </m-container>
    </section>

    <!-- ----- BONUS ----- -->
    <section id="bonus" class="py-12 bg-bg-light">
      <m-container>
        <div
          class="bg-navy-deep rounded-lg p-8 lg:p-12 shadow-premium relative overflow-hidden flex flex-col md:flex-row items-center gap-8 border border-white/10"
        >
          <div
            class="absolute -right-20 -bottom-20 w-64 h-64 bg-brand-blue/20 rounded-full blur-[80px] pointer-events-none"
          >
          </div>

          <div
            class="w-24 h-24 bg-brand-blue/10 rounded-full flex items-center justify-center shrink-0 border border-brand-blue/20"
          >
            <m-icon class="material-symbols-outlined text-5xl text-brand-blue"
              >featured_seasonal_and_gifts</m-icon
            >
          </div>

          <div class="flex-1 text-center md:text-left z-10">
            <h2
              class="text-2xl lg:text-3xl font-display font-bold text-white mb-2"
            >
              ¡Y DE REGALO!
            </h2>
            <h3 class="text-xl text-brand-blue font-semibold mb-4">
              Plan de acción estratégico escrito
            </h3>
            <p class="text-slate-300">
              Si nos dejas una reseña en audio tras la sesión, te prepararemos
              un documento detallado con el análisis completo y los pasos
              exactos para implementar.
            </p>
          </div>
        </div>
      </m-container>
    </section>

    <!-- ----- TESTIMONIALS ----- -->
    <section id="testimonials" class="py-20 bg-white">
      <m-container class="max-w-[--width-wide]">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="titleCapitalice text-brand-blue">Casos de Éxito</p>
          <h2
            class="text-3xl lg:text-4xl font-display font-bold text-navy mb-4"
          >
            Escucha a los que tuvieron la sesión
          </h2>
          <p class="text-lg text-slate-600">
            Empresas reales que transformaron su estrategia tras nuestro
            diagnóstico.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <TestimonialVideoCard
            videoUrl="https://youtu.be/F2b326QCG48"
            quote="Nos ayudaron a optimizar las campañas activas, mejorar la calidad de los leads y también entender mejor qué métricas analizar para tomar decisiones."
            authorName="José Antonio Nader Ríos"
            authorRole="Founder, Transvecto Logistics"
          />
          <TestimonialVideoCard
            videoUrl="https://youtu.be/4nN3gD1UG28"
            quote="Con su asesoramiento y tecnología logramos más leads calificados y optimizamos la inversión desde el primer mes de trabajo conjunto."
            authorName="José Caragol"
            authorRole="Marketing Digital, Rentokil Initial"
          />
          <TestimonialVideoCard
            videoUrl="https://youtu.be/333-y5EC8gw"
            quote="Mejoramos la performance de nuestras campañas, bajamos el costo por contacto y aumentamos las oportunidades comerciales reales."
            authorName="Victoria Vallas"
            authorRole="CMO, EV Chargers"
          />

          <TestimonialVideoCard
            videoUrl="https://youtu.be/ryhfo6CsySI"
            quote="Redujimos el costo por lead un 35% y duplicamos la tasa de conversión en solo cuatro semanas, sin aumentar la inversión mensual."
            authorName="Luis Suarez"
            authorRole="COO, EVA México"
          />
          <TestimonialVideoCard
            videoUrl="https://youtu.be/_4Rw2-iD_Xc"
            quote="En el primer mes mejoramos las campañas, aumentamos los leads útiles y recibimos asesoramiento clave para ajustar todo a tiempo."
            authorName="Sara Zambrano Morón"
            authorRole="Jefa de Marketing, Llegó"
          />
          <TestimonialVideoCard
            videoUrl="https://youtu.be/qodfPZ9d-AQ"
            quote="Gracias a su enfoque en performance logramos más contactos útiles y mejoramos el retorno de inversión rápidamente."
            authorName="Adrían Reyes"
            authorRole="Director de Marketing, Caliza"
          />
        </div>
      </m-container>
    </section>

    <!-- ----- AUDIENCE ----- -->
    <section id="audience" class="py-20 bg-bg-light">
      <m-container>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16">
          <!-- Para quién SI -->
          <div
            class="bg-brand-blue/5 rounded-xl p-8 lg:p-12 border border-brand-blue/20 relative overflow-hidden"
          >
            <div
              class="absolute -right-12 -top-12 w-48 h-48 bg-brand-blue/10 rounded-full blur-3xl pointer-events-none"
            >
            </div>

            <div
              class="w-12 h-12 bg-brand-blue/20 rounded-full flex items-center justify-center mb-6 relative z-10"
            >
              <m-icon class="material-symbols-outlined text-brand-blue"
                >check_circle</m-icon
              >
            </div>
            <h2
              class="text-3xl font-display font-bold text-navy mb-8 relative z-10"
            >
              ¿Para quién <span class="text-brand-blue block"
                >es esta sesión?</span
              >
            </h2>
            <ul class="flex flex-col gap-6 relative z-10">
              <li class="flex items-start gap-4">
                <m-icon
                  class="material-symbols-outlined text-brand-blue shrink-0 mt-0.5"
                  >check</m-icon
                >
                <p class="text-slate-800 font-medium">
                  <strong>Empresas que ya invierten en publicidad</strong> pero no
                  logran los resultados esperados.
                </p>
              </li>
              <li class="flex items-start gap-4">
                <m-icon
                  class="material-symbols-outlined text-brand-blue shrink-0 mt-0.5"
                  >check</m-icon
                >
                <p class="text-slate-800 font-medium">
                  <strong>Dueños de negocio y equipos comerciales</strong> que quieren
                  generar más oportunidades reales, no likes.
                </p>
              </li>
              <li class="flex items-start gap-4">
                <m-icon
                  class="material-symbols-outlined text-brand-blue shrink-0 mt-0.5"
                  >check</m-icon
                >
                <p class="text-slate-800 font-medium">
                  <strong>Empresas B2B o B2C</strong> con productos o servicios concretos,
                  y que tienen sitio web activo.
                </p>
              </li>
            </ul>
          </div>

          <!-- Para quién NO -->
          <div
            class="bg-slate-50 rounded-xl p-8 lg:p-12 border border-slate-200"
          >
            <div
              class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mb-6"
            >
              <m-icon class="material-symbols-outlined text-red-500"
                >cancel</m-icon
              >
            </div>
            <h2 class="text-3xl font-display font-bold text-navy mb-8">
              ¿Para quién <span class="text-red-500 block"
                >NO es esta sesión?</span
              >
            </h2>
            <ul class="flex flex-col gap-6">
              <li class="flex items-start gap-3">
                <m-icon
                  class="material-symbols-outlined text-slate-400 shrink-0 mt-0.5"
                  >close</m-icon
                >
                <p class="text-slate-600">
                  <strong>Emprendimientos</strong> en etapa de idea, sin validación
                  ni estructura comercial.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <m-icon
                  class="material-symbols-outlined text-slate-400 shrink-0 mt-0.5"
                  >close</m-icon
                >
                <p class="text-slate-600">
                  <strong>Proyectos personales</strong>, artísticos o sin fines
                  comerciales.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <m-icon
                  class="material-symbols-outlined text-slate-400 shrink-0 mt-0.5"
                  >close</m-icon
                >
                <p class="text-slate-600">
                  Empresas que buscan <strong>solo presencia</strong> en redes o no
                  están listas para invertir.
                </p>
              </li>
            </ul>
          </div>
        </div>
      </m-container>
    </section>

    <!-- ----- FAQ ----- -->
    <section id="faq" class="py-20 bg-white">
      <m-container>
        <div class="text-center mb-16">
          <h2
            class="text-3xl lg:text-4xl font-display font-bold text-navy mb-4"
          >
            Preguntas frecuentes
          </h2>
          <p class="text-lg text-slate-600">
            Respuestas a las dudas más comunes sobre nuestra auditoría gratuita.
          </p>
        </div>

        <div class="flex flex-col gap-0 border-t border-slate-200">
          <FaqAccordion
            question="¿Realmente es gratis o hay algún costo oculto?"
          >
            Sí, es 100% gratuita y sin compromiso. No tienes que contratar nada
            después. Es una forma de mostrarte cómo trabajamos y cómo podríamos
            ayudarte.
          </FaqAccordion>
          <FaqAccordion question="¿Qué voy a obtener en la sesión?">
            Un análisis concreto de tu situación, un plan de acción estratégico
            y una estimación de resultados posibles. Todo personalizado, en base
            a tus objetivos y etapa digital.
          </FaqAccordion>
          <FaqAccordion question="¿Cuánto dura y cómo se hace?">
            La sesión dura 25 minutos, se hace por videollamada (Google Meet o
            Zoom), y está dividida en dos partes: te conocemos y luego te
            asesoramos con propuestas concretas.
          </FaqAccordion>
          <FaqAccordion question="¿Con quién voy a tener la sesión?">
            Un estratega de nuestro equipo de MediaBros, con experiencia real
            gestionando campañas en toda LATAM para empresas como la tuya. No es
            un bot, ni un vendedor junior.
          </FaqAccordion>
        </div>
      </m-container>
    </section>

    <!-- ----- CTA BOTTOM ----- -->
    <section id="cta" class="py-20 bg-bg-light">
      <m-container>
        <div
          class="bg-brand-blue rounded-lg shadow-blue p-10 lg:p-16 text-center text-white relative overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10 mix-blend-overlay"
          >
          </div>

          <div class="relative z-10 max-w-3xl mx-auto">
            <h2
              class="text-3xl lg:text-4xl font-display font-bold mb-6 leading-tight"
            >
              No te sigas perdiendo oportunidades por falta de estrategia.
            </h2>
            <p class="text-lg lg:text-xl text-blue-100 mb-10">
              Agenda tu sesión gratuita y descubre qué está frenando tus
              resultados, qué puedes mejorar y cómo hacerlo con foco.
            </p>
            <a
              href="#hero"
              class="inline-flex items-center gap-3 bg-white text-brand-blue hover:bg-slate-50 font-bold px-8 py-5 rounded-md shadow-card transition-base text-lg"
            >
              <m-icon class="material-symbols-outlined">event_available</m-icon>
              Quiero agendar mi sesión estratégica
            </a>
          </div>
        </div>
      </m-container>
    </section>
  </main>

  <Footer />
</Layout>
